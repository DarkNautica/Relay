# ─────────────────────────────────────────────
# Relay Server Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
RELAY_HOST=0.0.0.0
RELAY_PORT=6001

# Application Credentials
# These must match what your backend and frontend use
RELAY_APP_ID=my-app
RELAY_APP_KEY=my-key-change-me
RELAY_APP_SECRET=my-secret-change-me

# Connection Limits
RELAY_MAX_CONNECTIONS=10000
RELAY_MAX_CHANNEL_NAME_LENGTH=200
RELAY_MAX_EVENT_PAYLOAD_KB=100

# Keep-Alive (seconds)
RELAY_PING_INTERVAL=120
RELAY_PING_TIMEOUT=30

# Dashboard
RELAY_DASHBOARD_ENABLED=true
RELAY_DASHBOARD_PATH=/dashboard

# Debug — set to true for verbose logging (never in production)
RELAY_DEBUG=false
